PORT=8080
# Base URL pública usada para montar o link dentro do QR Code (ex.: https://api.seudominio.com)
CARDS_PUBLIC_BASE_URL=http://localhost:8080
# Diretório para persistir cartões (JSON). Em Docker, monte um volume para /app/data.
CARDS_DATA_DIR=./data
# Opcional no Vercel: se BLOB_READ_WRITE_TOKEN estiver definido, /cards usa Vercel Blob.
VERCEL_BLOB_STORE_ID=store_3NzMc2i8xq3vySBn
VERCEL_BLOB_CARDS_PATH=visitas/cards.json
BLOB_READ_WRITE_TOKEN=

GOOGLE_WALLET_ORIGINS=https://example.com
GOOGLE_WALLET_ISSUER_ID=0000000000000000000
GOOGLE_WALLET_CLASS_SUFFIX=visitas_card
GOOGLE_WALLET_ISSUER_NAME=Visitas
# Opcional: use a classId completa (issuerId.suffix) no lugar das duas vars acima.
# GOOGLE_WALLET_CLASS_ID=0000000000000000000.visitas_card
GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account@project-id.iam.gserviceaccount.com
# Keep line breaks escaped as \n when copying from the service-account JSON file.
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
