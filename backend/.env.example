PORT=8080
# Base URL pública usada para montar o link dentro do QR Code (ex.: https://api.seudominio.com)
CARDS_PUBLIC_BASE_URL=http://localhost:8080
# Diretório para persistir cartões (JSON). Em Docker, monte um volume para /app/data.
CARDS_DATA_DIR=./data

GOOGLE_WALLET_ORIGINS=https://example.com
GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account@project-id.iam.gserviceaccount.com
# Keep line breaks escaped as \n when copying from the service-account JSON file.
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
